<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GHelper.Linux.UI.Views.MouseWindow"
        Title="Mouse Settings"
        Width="420"
        Height="680"
        MinWidth="360"
        MinHeight="400"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        Background="#1C1C1C"
        Icon="avares://ghelper/UI/Assets/standard.ico">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12" Spacing="6">

            <!-- Device -->
            <Border Classes="panel">
                <StackPanel>
                    <Border Classes="panel-header" Margin="0,0,0,8">
                        <TextBlock Classes="header" Text="Device" />
                    </Border>

                    <TextBlock x:Name="labelDevice" Classes="value" Text="No ASUS mouse detected" />

                    <Grid x:Name="rowBattery" ColumnDefinitions="130,*" Margin="0,6,0,0">
                        <TextBlock Grid.Column="0" Classes="label-dim" Text="Battery" />
                        <TextBlock Grid.Column="1" x:Name="labelBattery" Classes="value" Text="--" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- DPI -->
            <Border x:Name="panelDpi" Classes="panel">
                <StackPanel>
                    <Border Classes="panel-header" Margin="0,0,0,8">
                        <TextBlock Classes="header" Text="DPI" />
                    </Border>

                    <Grid ColumnDefinitions="130,*" Margin="0,4">
                        <TextBlock Grid.Column="0" Classes="label-dim" Text="Active Profile"
                                   VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" x:Name="comboDpiProfile"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="ComboDpiProfile_Changed" />
                    </Grid>

                    <Grid ColumnDefinitions="130,*,60" Margin="0,4">
                        <TextBlock Grid.Column="0" Classes="label-dim" Text="DPI"
                                   VerticalAlignment="Center" />
                        <Slider Grid.Column="1" x:Name="sliderDpi"
                                Minimum="100" Maximum="36000" Value="800"
                                TickFrequency="50" IsSnapToTickEnabled="True"
                                ValueChanged="SliderDpi_Changed" />
                        <TextBlock Grid.Column="2" x:Name="labelDpiValue" Classes="value" Text="800"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Performance -->
            <Border x:Name="panelPerformance" Classes="panel">
                <StackPanel>
                    <Border Classes="panel-header" Margin="0,0,0,8">
                        <TextBlock Classes="header" Text="Performance" />
                    </Border>

                    <Grid ColumnDefinitions="130,*" Margin="0,4">
                        <TextBlock Grid.Column="0" Classes="label-dim" Text="Polling Rate"
                                   VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" x:Name="comboPollingRate"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="ComboPollingRate_Changed" />
                    </Grid>

                    <Grid x:Name="rowAngleSnapping" ColumnDefinitions="130,*" Margin="0,4">
                        <TextBlock Grid.Column="0" Classes="label-dim" Text="Angle Snapping"
                                   VerticalAlignment="Center" />
                        <CheckBox Grid.Column="1" x:Name="checkAngleSnapping"
                                  IsCheckedChanged="CheckAngleSnapping_Changed" />
                    </Grid>

                    <Grid x:Name="rowDebounce" ColumnDefinitions="130,*" Margin="0,4">
                        <TextBlock Grid.Column="0" Classes="label-dim" Text="Button Debounce"
                                   VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" x:Name="comboDebounce"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="ComboDebounce_Changed" />
                    </Grid>

                    <Grid x:Name="rowLiftOff" ColumnDefinitions="130,*" Margin="0,4">
                        <TextBlock Grid.Column="0" Classes="label-dim" Text="Lift-Off Distance"
                                   VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" x:Name="comboLiftOff"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="ComboLiftOff_Changed" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Energy -->
            <Border x:Name="panelEnergy" Classes="panel">
                <StackPanel>
                    <Border Classes="panel-header" Margin="0,0,0,8">
                        <TextBlock Classes="header" Text="Energy" />
                    </Border>

                    <Grid x:Name="rowPowerOff" ColumnDefinitions="130,*" Margin="0,4">
                        <TextBlock Grid.Column="0" Classes="label-dim" Text="Auto Power Off"
                                   VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" x:Name="comboPowerOff"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="ComboPowerOff_Changed" />
                    </Grid>

                    <Grid x:Name="rowLowBattery" ColumnDefinitions="130,*,60" Margin="0,4">
                        <TextBlock Grid.Column="0" Classes="label-dim" Text="Low Battery Warning"
                                   TextWrapping="Wrap" VerticalAlignment="Center" />
                        <Slider Grid.Column="1" x:Name="sliderLowBattery"
                                Minimum="0" Maximum="50" Value="25"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                ValueChanged="SliderLowBattery_Changed" />
                        <TextBlock Grid.Column="2" x:Name="labelLowBattery" Classes="value" Text="25%"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Lighting -->
            <Border x:Name="panelLighting" Classes="panel">
                <StackPanel>
                    <Border Classes="panel-header" Margin="0,0,0,8">
                        <TextBlock Classes="header" Text="Lighting" />
                    </Border>

                    <Grid x:Name="rowZone" ColumnDefinitions="130,*" Margin="0,4">
                        <TextBlock Grid.Column="0" Classes="label-dim" Text="Zone"
                                   VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" x:Name="comboLightingZone"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="ComboLightingZone_Changed" />
                    </Grid>

                    <Grid ColumnDefinitions="130,*" Margin="0,4">
                        <TextBlock Grid.Column="0" Classes="label-dim" Text="Mode"
                                   VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" x:Name="comboLightingMode"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="ComboLightingMode_Changed" />
                    </Grid>

                    <Grid ColumnDefinitions="130,*,60" Margin="0,4">
                        <TextBlock Grid.Column="0" Classes="label-dim" Text="Brightness"
                                   VerticalAlignment="Center" />
                        <Slider Grid.Column="1" x:Name="sliderBrightness"
                                Minimum="0" Maximum="100" Value="100"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="SliderBrightness_Changed" />
                        <TextBlock Grid.Column="2" x:Name="labelBrightness" Classes="value" Text="100"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>

                    <Grid ColumnDefinitions="130,Auto,Auto" Margin="0,4">
                        <TextBlock Grid.Column="0" Classes="label-dim" Text="Color"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="1" x:Name="borderColor"
                                Width="40" Height="24" CornerRadius="4"
                                Background="White" VerticalAlignment="Center" />
                        <Button Grid.Column="2" x:Name="buttonColor" Classes="ghelper"
                                Content="Pick Color" Margin="8,0,0,0"
                                Click="ButtonColor_Click" />
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Window>
