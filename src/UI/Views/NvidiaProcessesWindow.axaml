<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="using:GHelper.Linux.UI.Controls"
        x:Class="GHelper.Linux.UI.Views.NvidiaProcessesWindow"
        Title="Processes using dGPU"
        Width="520"
        MinWidth="420"
        MinHeight="300"
        MaxHeight="450"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        Background="#1C1C1C"
        Icon="avares://ghelper/UI/Assets/standard.ico">

    <Window.Styles>
        <Style Selector="ScrollBar:vertical">
            <Setter Property="Width" Value="12" />
        </Style>
        <Style Selector="ScrollBar /template/ Thumb">
            <Setter Property="RenderTransform" Value="none" />
            <Setter Property="Background" Value="#5A5A5A" />
            <Setter Property="MinHeight" Value="30" />
        </Style>
        <Style Selector="ScrollBar /template/ Thumb:pointerover">
            <Setter Property="Background" Value="#7A7A7A" />
        </Style>
        <Style Selector="ScrollBar /template/ Thumb:pressed">
            <Setter Property="Background" Value="#909090" />
        </Style>
        <Style Selector="ScrollBar /template/ Rectangle#TrackRect">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Fill" Value="#2A2A2A" />
        </Style>
    </Window.Styles>

    <Grid Margin="12" RowDefinitions="Auto,*">

        <Border Grid.Row="0" Classes="panel">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <ctrl:Icon IconName="gamepad" Width="18" Height="18" VerticalAlignment="Center" />
                    <TextBlock x:Name="labelHeader" Classes="header"
                               Text="0 processes using dGPU" VerticalAlignment="Center" />
                </StackPanel>
                <Button Grid.Column="1" x:Name="buttonRefresh" Classes="ghelper"
                        Click="ButtonRefresh_Click" Padding="10,4" FontSize="11">
                    <TextBlock x:Name="labelRefresh" Text="Refresh" VerticalAlignment="Center" />
                </Button>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      AllowAutoHide="False"
                      Margin="0,8,0,0">
            <StackPanel x:Name="panelProcessList" Spacing="4" Margin="0,0,2,0" />
        </ScrollViewer>

    </Grid>
</Window>
