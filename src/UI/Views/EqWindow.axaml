<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:GHelper.Linux.UI.Controls"
        x:Class="GHelper.Linux.UI.Views.EqWindow"
        Title="Parametric EQ"
        Width="640"
        Height="380"
        MinWidth="500"
        MinHeight="280"
        WindowStartupLocation="CenterScreen"
        Background="#1C1C1C"
        Icon="avares://ghelper/UI/Assets/favicon.ico">
    <Grid RowDefinitions="*,Auto" Margin="10">
        <Border Grid.Row="0" Classes="panel" Padding="6">
            <ctrl:EqResponseView x:Name="eqView" />
        </Border>
        <Border Grid.Row="1" Classes="panel" Padding="6" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <TextBlock x:Name="labelHint"
                           Text="Drag handles for freq/gain. Scroll wheel over a handle adjusts Q (steepness). Shift+wheel = coarser."
                           FontSize="11" Foreground="#888" VerticalAlignment="Center"
                           TextWrapping="Wrap" MaxWidth="420" />
                <Button x:Name="buttonReset" Content="Reset" Click="ButtonReset_Click"
                        Width="80" />
                <Button x:Name="buttonBypass" Content="Bypass" Click="ButtonBypass_Click"
                        Width="80" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
