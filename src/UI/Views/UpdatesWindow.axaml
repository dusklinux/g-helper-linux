<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GHelper.Linux.UI.Views.UpdatesWindow"
        Title="BIOS &amp; Driver Updates"
        Width="700"
        Height="600"
        MinWidth="500"
        MinHeight="400"
        WindowStartupLocation="Manual"
        CanResize="True"
        Background="#1C1C1C"
        Icon="avares://ghelper/UI/Assets/standard.ico">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <StackPanel Margin="12,8,12,8" Spacing="8">

            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                <TextBlock x:Name="labelTitle" Grid.Column="0"
                           Text="BIOS &amp; Driver Updates"
                           Foreground="#F0F0F0" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="labelUpdates" Grid.Column="1"
                           Text="Checking..."
                           Foreground="#06B48A" FontSize="13"
                           VerticalAlignment="Center" Margin="0,0,12,0" />
                <Button x:Name="buttonDiagnostics" Grid.Column="2"
                        Content="Copy Diagnostics" Click="ButtonDiagnostics_Click"
                        MinWidth="120" Margin="0,0,6,0" />
                <Button x:Name="buttonExportDiag" Grid.Column="3"
                        Content="Export Diagnostics" Click="ButtonExportDiag_Click"
                        MinWidth="120" Margin="0,0,6,0" />
                <Button x:Name="buttonRefresh" Grid.Column="4"
                        Content="Refresh" Click="ButtonRefresh_Click"
                        MinWidth="80" />
            </Grid>

            <!-- G-Helper version -->
            <Border Background="#262626" CornerRadius="6" Padding="10,6">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock x:Name="labelAppVersion" Grid.Column="0"
                               Text="G-Helper Linux v1.0.0"
                               Foreground="#F0F0F0" FontSize="12"
                               VerticalAlignment="Center" />
                    <Button x:Name="buttonChangelog" Grid.Column="1"
                            Content="What's new" Click="ButtonChangelog_Click"
                            MinWidth="100" Padding="8,2" />
                </Grid>
            </Border>

            <!-- Legend -->
            <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Border Width="12" Height="12" CornerRadius="2" Background="#06B48A" />
                    <TextBlock x:Name="labelLegendUpToDate" Text="Up to date" Foreground="#999999" FontSize="11" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Border Width="12" Height="12" CornerRadius="2" Background="#FF2020" />
                    <TextBlock x:Name="labelLegendUpdateAvailable" Text="Update available" Foreground="#999999" FontSize="11" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Border Width="12" Height="12" CornerRadius="2" Background="#666666" />
                    <TextBlock x:Name="labelLegendCantCheck" Text="Can't check" Foreground="#999999" FontSize="11" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>

            <!-- System integration files (self-installer) -->
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,8,0,0">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6"
                            Cursor="Hand" Background="Transparent"
                            VerticalAlignment="Center"
                            PointerPressed="SysFilesHeader_PointerPressed">
                    <TextBlock x:Name="labelSystemFilesSection"
                               Text="System integration files"
                               Foreground="#F0F0F0" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Path x:Name="iconSysFilesToggle"
                          Data="M 0,0 L 0,12 L 12,6 Z"
                          Fill="#F0F0F0"
                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                </StackPanel>
                <Button x:Name="buttonSysFilesRecheck" Grid.Column="1"
                        Content="Re-check" Click="ButtonSysFilesRecheck_Click"
                        MinWidth="90" Margin="0,0,6,0" Padding="8,2" />
                <Button x:Name="buttonSysFilesFix" Grid.Column="2"
                        Content="Install / Repair" Click="ButtonSysFilesFix_Click"
                        MinWidth="120" Padding="8,2" />
                <Button x:Name="buttonSysFilesUninstall" Grid.Column="3"
                        Content="Uninstall" Click="ButtonSysFilesUninstall_Click"
                        MinWidth="90" Margin="6,0,0,0" Padding="8,2" />
            </Grid>
            <Border x:Name="panelSysFilesBody" Background="#262626" CornerRadius="6" Padding="10,8"
                    IsVisible="False">
                <StackPanel Spacing="2">
                    <StackPanel x:Name="panelSystemFiles" Spacing="2" />
                    <TextBlock x:Name="labelSysFilesResult" Text=""
                               Foreground="#999999" FontSize="11" Margin="0,6,0,0"
                               IsVisible="False" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- G-Helper Linux self-update -->
            <TextBlock x:Name="labelGHelperSection" Text="G-Helper Linux" Foreground="#F0F0F0" FontSize="14" FontWeight="SemiBold" Margin="0,8,0,4" />
            <Border Background="#262626" CornerRadius="6" Padding="10,6">
                <StackPanel x:Name="panelSelfUpdate" Spacing="4">
                    <TextBlock x:Name="labelSelfUpdateStatus" Text="Checking for updates..." Foreground="#999999" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- BIOS Section -->
            <TextBlock x:Name="labelBiosSection" Text="BIOS" Foreground="#F0F0F0" FontSize="14" FontWeight="SemiBold" Margin="0,8,0,4" />
            <Border Background="#262626" CornerRadius="6" Padding="8">
                <StackPanel x:Name="panelBios" Spacing="2">
                    <TextBlock x:Name="labelBiosLoading" Text="Loading..." Foreground="#999999" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Drivers Section -->
            <TextBlock x:Name="labelDriversSection" Text="Drivers &amp; Software" Foreground="#F0F0F0" FontSize="14" FontWeight="SemiBold" Margin="0,8,0,4" />
            <Border Background="#262626" CornerRadius="6" Padding="8">
                <StackPanel x:Name="panelDrivers" Spacing="2">
                    <TextBlock x:Name="labelDriversLoading" Text="Loading..." Foreground="#999999" FontSize="12" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Window>
