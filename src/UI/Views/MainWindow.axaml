<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:GHelper.Linux.UI.Controls"
        x:Class="GHelper.Linux.UI.Views.MainWindow"
        Title="G-Helper"
        Width="462"
        SizeToContent="Height"
        MinWidth="380"
        MinHeight="510"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        WindowDecorations="Full"
        Background="#1C1C1C"
        Icon="avares://ghelper/UI/Assets/favicon.ico">

    <Window.Styles>
        <!-- Active button gets accent border (perf, GPU, screen modes) -->
        <Style Selector="Button.mode-active">
            <Setter Property="BorderBrush" Value="#4CC2FF" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="Button.fnlock-on">
            <Setter Property="Background" Value="#4CC2FF" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#4CC2FF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button.fnlock-on:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#5FCDFF" />
        </Style>
        <Style Selector="Button.fnlock-on:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#3AAEEF" />
        </Style>
        <!-- audio-on mirrors fnlock-on but in a greener accent to signal
             "noise suppression / DSP chain active" without clashing with
             the existing perf / GPU blue. -->
        <Style Selector="Button.audio-on">
            <Setter Property="Background" Value="#50C878" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#50C878" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button.audio-on:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#67D48B" />
        </Style>
        <Style Selector="Button.audio-on:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#3FB565" />
        </Style>
    </Window.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <StackPanel Margin="11,8,11,8" Spacing="0">

            <!-- PERFORMANCE SECTION -->
            <Border Classes="panel">
                <StackPanel>
                    <!-- Title row: icon + label left, sensor info right -->
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="2,0,2,8">
                        <ctrl:Icon Grid.Column="0" IconName="bolt" Bold="True"
                                   Width="18" Height="18"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="1" x:Name="labelPerf" Classes="header"
                                   Text="Mode: Balanced" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" x:Name="labelCPUFan" Classes="label-dim"
                                   Text="CPU: - °C  Fan: 0RPM" VerticalAlignment="Center" />
                    </Grid>

                    <!-- Performance mode buttons, equal width, tall, icon above text -->
                    <UniformGrid Rows="1" Columns="4" Margin="0,0">
                        <Button x:Name="buttonSilent" Classes="ghelper-tall"
                                Margin="0,0,3,0" Click="ButtonSilent_Click">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <ctrl:Icon IconName="leaf" Width="24" Height="24" HorizontalAlignment="Center" />
                                <TextBlock Text="Silent" HorizontalAlignment="Center" FontSize="11" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="buttonBalanced" Classes="ghelper-tall"
                                Margin="3,0" Click="ButtonBalanced_Click">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <ctrl:Icon IconName="balance" Width="24" Height="24" HorizontalAlignment="Center" />
                                <TextBlock Text="Balanced" HorizontalAlignment="Center" FontSize="11" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="buttonTurbo" Classes="ghelper-tall"
                                Margin="3,0" Click="ButtonTurbo_Click">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <ctrl:Icon IconName="rocket" Width="24" Height="24" HorizontalAlignment="Center" />
                                <TextBlock Text="Turbo" HorizontalAlignment="Center" FontSize="11" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="buttonFans" Classes="ghelper-tall"
                                Margin="3,0,0,0" Click="ButtonFans_Click">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <ctrl:Icon IconName="cyclone" Width="24" Height="24" HorizontalAlignment="Center" />
                                <TextBlock Text="Fans + Power" HorizontalAlignment="Center" FontSize="11" />
                            </StackPanel>
                        </Button>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- GPU SECTION -->
            <Border x:Name="panelGPU" Classes="panel">
                <StackPanel>
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="2,0,2,8">
                        <ctrl:Icon Grid.Column="0" IconName="gamepad" Bold="True"
                                   Width="18" Height="18"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="1" x:Name="labelGPU" Classes="header"
                                   Text="GPU Mode: Standard" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" x:Name="labelGPUFan" Classes="label-dim"
                                   Text="GPU Fan: 0RPM" VerticalAlignment="Center" />
                    </Grid>

                    <!-- GPU mode buttons, 4 modes matching Windows G-Helper.
                         Hidden entirely on Ally (no dGPU / no MUX) - replaced
                         by the XGM dock button below when an XG Mobile is
                         attached. Match Windows g-helper Settings.cs:1810.
                         Columns is set at runtime to the count of visible
                         buttons (RefreshGpuMode) so hidden Ultimate/Optimized
                         slots collapse instead of leaving blank space.
                         ColumnSpacing replaces per-button margins so the
                         spacing stays uniform regardless of which buttons
                         are visible. -->
                    <UniformGrid x:Name="panelGpuModes" Rows="1" Columns="4"
                                 ColumnSpacing="6" Margin="0,0">
                        <Button x:Name="buttonEco" Classes="ghelper-tall"
                                Click="ButtonEco_Click">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <ctrl:Icon IconName="herb" Width="24" Height="24" HorizontalAlignment="Center" />
                                <TextBlock Text="Eco" HorizontalAlignment="Center" FontSize="11" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="buttonStandard" Classes="ghelper-tall"
                                Click="ButtonStandard_Click">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <ctrl:Icon IconName="desktop" Width="24" Height="24" HorizontalAlignment="Center" />
                                <TextBlock Text="Standard" HorizontalAlignment="Center" FontSize="11" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="buttonUltimate" Classes="ghelper-tall"
                                Click="ButtonUltimate_Click">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <ctrl:Icon IconName="gamepad" Width="24" Height="24" HorizontalAlignment="Center" />
                                <TextBlock Text="Ultimate" HorizontalAlignment="Center" FontSize="11" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="buttonOptimized" Classes="ghelper-tall"
                                Click="ButtonOptimized_Click">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <ctrl:Icon IconName="bulb" Width="24" Height="24" HorizontalAlignment="Center" />
                                <TextBlock Text="Optimized" HorizontalAlignment="Center" FontSize="11" />
                            </StackPanel>
                        </Button>
                    </UniformGrid>

                    <!-- XG Mobile (eGPU dock) toggle. Visible when an XG Mobile
                         dock is detected via egpu_connected==1 - works on every
                         ROG model with the receptacle (Flow X13/X16/Z13, Strix
                         XG, ROG Ally). Click toggles egpu_enable; on dual-backend
                         kernels the legacy asus-nb-wmi write usually takes effect
                         immediately, on asus-armoury-only kernels a reboot is
                         needed (the click handler picks the right user message
                         based on which backend wrote successfully). -->
                    <Button x:Name="buttonXGM" Classes="ghelper"
                            Margin="0,4,0,0" Click="ButtonXGM_Click"
                            Height="36" IsVisible="False">
                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                            <ctrl:Icon IconName="package" Width="14" Height="14" VerticalAlignment="Center" />
                            <TextBlock x:Name="labelXGM" Text="XG Mobile" FontSize="11" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <TextBlock x:Name="labelTipGPU" Classes="label-dim"
                               Text="" Margin="2,6,2,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- SCREEN SECTION -->
            <Border Classes="panel">
                <StackPanel>
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="2,0,2,8">
                        <ctrl:Icon Grid.Column="0" IconName="desktop" Bold="True"
                                   Width="18" Height="18"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="1" x:Name="labelScreen" Classes="header"
                                   Text="Laptop Screen: 60Hz" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" x:Name="labelMidFan" Classes="label-dim"
                                   Text="" VerticalAlignment="Center" />
                    </Grid>

                    <!-- Screen buttons, equal width -->
                    <UniformGrid Rows="1" Columns="3" Margin="0,0">
                        <Button x:Name="buttonScreenAuto" Classes="ghelper"
                                Margin="0,0,3,0" Click="ButtonScreenAuto_Click"
                                Height="36">
                            <TextBlock Text="Auto" HorizontalAlignment="Center" FontSize="11" />
                        </Button>
                        <Button x:Name="button60Hz" Classes="ghelper"
                                Margin="3,0" Click="Button60Hz_Click"
                                Height="36">
                            <TextBlock Text="60Hz" HorizontalAlignment="Center" FontSize="11" />
                        </Button>
                        <Button x:Name="button120Hz" Classes="ghelper"
                                Margin="3,0,0,0" Click="Button120Hz_Click"
                                Height="36">
                            <TextBlock x:Name="labelHighRefresh" Text="120Hz"
                                       HorizontalAlignment="Center" FontSize="11" />
                        </Button>
                    </UniformGrid>
                    <!-- MiniLED button, only visible on supported models -->
                    <Button x:Name="buttonMiniled" Classes="ghelper"
                            Margin="0,4,0,0" Click="ButtonMiniled_Click"
                            Height="36" IsVisible="False">
                        <TextBlock Text="MiniLED" HorizontalAlignment="Center" FontSize="11" />
                    </Button>
                </StackPanel>
            </Border>

            <!-- ROG ALLY HANDHELD SECTION (visible only on Ally / Ally X) -->
            <Border x:Name="panelAlly" Classes="panel" IsVisible="False">
                <StackPanel>
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="2,0,2,8">
                        <ctrl:Icon Grid.Column="0" IconName="gamepad" Bold="True"
                                   Width="18" Height="18"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="1" x:Name="labelAllyHeader" Classes="header"
                                   Text="Handheld" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" x:Name="labelAllyMetrics" Classes="label-dim"
                                   Text="" VerticalAlignment="Center" />
                    </Grid>

                    <!-- Row 1: Controller mode + Backlight cycle -->
                    <Grid ColumnDefinitions="*,*" Margin="0,0,0,4">
                        <Button Grid.Column="0" x:Name="buttonControllerMode" Classes="ghelper"
                                Margin="0,0,3,0" Click="ButtonControllerMode_Click"
                                HorizontalAlignment="Stretch"
                                Height="36">
                            <TextBlock x:Name="labelControllerMode" Text="Mode: Auto"
                                       HorizontalAlignment="Center" FontSize="11" />
                        </Button>
                        <Button Grid.Column="1" x:Name="buttonAllyBacklight" Classes="ghelper"
                                Margin="3,0,0,0" Click="ButtonAllyBacklight_Click"
                                HorizontalAlignment="Stretch"
                                Height="36">
                            <TextBlock x:Name="labelAllyBacklight" Text="Backlight 100%"
                                       HorizontalAlignment="Center" FontSize="11" />
                        </Button>
                    </Grid>

                    <!-- Row 2: Open Handheld settings window -->
                    <Button x:Name="buttonOpenHandheld" Classes="ghelper"
                            Click="ButtonOpenHandheld_Click"
                            HorizontalAlignment="Stretch"
                            Height="36" Margin="0,0,0,0">
                        <TextBlock x:Name="labelOpenHandheld" Text="Bindings &amp; Deadzones..."
                                   HorizontalAlignment="Center" FontSize="11" />
                    </Button>
                </StackPanel>
            </Border>

            <!-- KEYBOARD SECTION -->
            <Border Classes="panel">
                <StackPanel>
                    <Grid ColumnDefinitions="Auto,Auto,*,Auto" Margin="2,0,2,8">
                        <ctrl:Icon Grid.Column="0" IconName="keyboard" Bold="True"
                                   Width="18" Height="18"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="1" x:Name="labelKeyboard" Classes="header"
                                   Text="Laptop Keyboard" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" x:Name="labelBacklight" Classes="label-dim"
                                   Text="" VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />
                        <Button Grid.Column="3" x:Name="buttonFnLock" Classes="ghelper"
                                Click="ButtonFnLock_Click"
                                Height="26" Padding="10,0"
                                MinWidth="78"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="labelFnLockButton"
                                       Text="FN-Lock"
                                       HorizontalAlignment="Center"
                                       FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </Button>
                    </Grid>

                    <!-- Row 1: Backlight cycle + Extra settings. -->
                    <Grid ColumnDefinitions="*,*" Margin="0,0,0,4">
                        <Button Grid.Column="0" x:Name="buttonKeyboard" Classes="ghelper"
                                Margin="0,0,3,0" Click="ButtonKeyboard_Click"
                                HorizontalAlignment="Stretch"
                                Height="36">
                            <TextBlock Text="Backlight" HorizontalAlignment="Center" FontSize="11" />
                        </Button>
                        <Button Grid.Column="1" x:Name="buttonExtra" Classes="ghelper"
                                Margin="3,0,0,0" Click="ButtonExtra_Click"
                                HorizontalAlignment="Stretch"
                                Height="36">
                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                <ctrl:Icon IconName="gear" Width="14" Height="14" VerticalAlignment="Center" />
                                <TextBlock Text="Extra" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Row 2: AURA Mode + Speed + Color1 + Color2 -->
                    <Grid ColumnDefinitions="*,90,44,44" Margin="0,0" x:Name="panelAura">
                        <ComboBox x:Name="comboAuraMode" Grid.Column="0"
                                  Height="36" Margin="0,0,4,0"
                                  HorizontalAlignment="Stretch"
                                  MaxDropDownHeight="300"
                                  SelectionChanged="ComboAuraMode_Changed" />
                        <ComboBox x:Name="comboAuraSpeed" Grid.Column="1"
                                  Height="36" Margin="2,0"
                                  HorizontalAlignment="Stretch"
                                  MaxDropDownHeight="200"
                                  SelectionChanged="ComboAuraSpeed_Changed" />
                        <Button x:Name="buttonColor1" Grid.Column="2"
                                Height="36" Width="36" Margin="2,0"
                                Click="ButtonColor1_Click"
                                ToolTip.Tip="Primary color"
                                Background="#FFFFFF"
                                CornerRadius="5" />
                        <Button x:Name="buttonColor2" Grid.Column="3"
                                Height="36" Width="36" Margin="2,0,0,0"
                                Click="ButtonColor2_Click"
                                ToolTip.Tip="Secondary color"
                                Background="#000000"
                                IsVisible="False"
                                CornerRadius="5" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- AUDIO SECTION (microphone noise suppression + DSP chain).
                 The header toggle on the right enables or disables the whole
                 audio helper, same UX shape as the FN-Lock button above. The
                 body button below opens the dedicated G-Helper Audio window
                 for fine-grained per-effect control. -->
            <Border x:Name="panelAudio" Classes="panel">
                <StackPanel>
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="2,0,2,8">
                        <TextBlock Grid.Column="0" Text="&#x1F399;"
                                   FontSize="16"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="1" x:Name="labelAudio" Classes="header"
                                   Text="Microphone"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="2" x:Name="buttonAudioToggle" Classes="ghelper"
                                Click="ButtonAudioToggle_Click"
                                Height="26" Padding="10,0"
                                MinWidth="78"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="labelAudioToggle"
                                       Text="Off"
                                       HorizontalAlignment="Center"
                                       FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </Button>
                    </Grid>

                    <Button x:Name="buttonAudio" Classes="ghelper"
                            Margin="0,0" Click="ButtonAudio_Click"
                            HorizontalAlignment="Stretch"
                            Height="36">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                            <ctrl:Icon IconName="equalizer" Width="16" Height="16"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="labelAudioConfigure"
                                       Text="Configure chain..." FontSize="11"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- BATTERY SECTION -->
            <Border Classes="panel">
                <StackPanel>
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="2,0,2,4">
                        <ctrl:Icon Grid.Column="0" IconName="battery" Bold="True"
                                   Width="18" Height="18"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="1" x:Name="labelBattery" Classes="header"
                                   Text="Battery Charge Limit: 100%"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" x:Name="labelCharge" Classes="label-dim"
                                   Text="" VerticalAlignment="Center" />
                    </Grid>

                    <!-- Battery charge limit slider -->
                    <Grid ColumnDefinitions="*,50" Margin="2,0,2,4">
                        <Slider x:Name="sliderBattery" Grid.Column="0"
                                Minimum="40" Maximum="100"
                                Value="100"
                                TickFrequency="10"
                                IsSnapToTickEnabled="False"
                                ValueChanged="SliderBattery_ValueChanged" />
                        <TextBlock x:Name="labelBatteryLimit" Grid.Column="1"
                                   Classes="value" Text="100%"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <!-- Quick presets -->
                    <UniformGrid Rows="1" Columns="3" Margin="0,0">
                        <Button x:Name="buttonBattery60" Classes="ghelper"
                                Margin="0,0,3,0" Click="ButtonBattery60_Click"
                                Height="32">
                            <TextBlock Text="60%" HorizontalAlignment="Center" FontSize="11" />
                        </Button>
                        <Button x:Name="buttonBattery80" Classes="ghelper"
                                Margin="3,0" Click="ButtonBattery80_Click"
                                Height="32">
                            <TextBlock Text="80%" HorizontalAlignment="Center" FontSize="11" />
                        </Button>
                        <Button x:Name="buttonBattery100" Classes="ghelper"
                                Margin="3,0,0,0" Click="ButtonBattery100_Click"
                                Height="32">
                            <TextBlock Text="100%" HorizontalAlignment="Center" FontSize="11" />
                        </Button>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- FOOTER -->
            <Border Classes="panel" Margin="3,4,3,3">
                <StackPanel Spacing="6">
                    <!-- Run on Startup + Charge info -->
                    <Grid ColumnDefinitions="*,Auto">
                        <CheckBox Grid.Column="0" x:Name="checkStartup" Content="Run on Startup"
                                  IsCheckedChanged="CheckStartup_Changed" />
                        <TextBlock Grid.Column="1" x:Name="labelChargeFooter" Classes="label-dim"
                                   Text="" VerticalAlignment="Center" />
                    </Grid>

                    <!-- System Info -->
                    <StackPanel Spacing="2" Margin="0,2,0,4">
                        <TextBlock x:Name="labelSysModel" Classes="label-dim" Text="" />
                        <TextBlock x:Name="labelSysBios" Classes="label-dim" Text="" />
                        <TextBlock x:Name="labelSysKernel" Classes="label-dim" Text="" />
                        <TextBlock x:Name="labelSysWmi" Classes="label-dim" Text="" />
                        <TextBlock x:Name="labelSysFeatures" Classes="label-dim" Text=""
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- Version -->
                    <TextBlock x:Name="labelVersion" Classes="label-dim" Cursor="Hand"
                               Text="G-Helper Linux v1.0.0" FontSize="12" Margin="0,0,0,6" />

                    <!-- Donate + Updates + Quit -->
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                        <Button Grid.Column="0" x:Name="buttonDonate" Classes="ghelper-coin"
                                Margin="0,0,6,0" Height="36" MinWidth="140"
                                Click="ButtonDonate_Click">
                            <Grid>
                                <StackPanel Orientation="Horizontal" Spacing="6"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Margin="0,0,24,0">
                                    <Border CornerRadius="12" Width="24" Height="24"
                                            Background="#B8860B" BorderBrush="#8B6914"
                                            BorderThickness="2" VerticalAlignment="Center">
                                        <TextBlock Text="$" FontWeight="Black" FontSize="15"
                                                   Foreground="#FFD700" FontFamily="monospace"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Margin="1,0,0,2" />
                                    </Border>
                                    <TextBlock x:Name="labelDonateText" Text="Donate" FontSize="12" FontWeight="Bold"
                                               Foreground="#4A3800" VerticalAlignment="Center" />
                                    <TextBlock x:Name="labelCoinCount" Text="" FontSize="12"
                                               VerticalAlignment="Center" FontWeight="Bold"
                                               Foreground="#8B6914" />
                                </StackPanel>
                                <!-- Mute toggle: ♪ when unmuted, M when muted -->
                                <Border x:Name="borderCoinMute" CornerRadius="3"
                                        Background="#B8860B" Padding="4,1"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Margin="0,0,3,0" Cursor="Hand">
                                    <TextBlock x:Name="labelCoinMute" Text="&#x266A;"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="#FFD700"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Button>
                        <Button Grid.Column="2" x:Name="buttonUpdates" Classes="ghelper"
                                Margin="0,0,4,0" Height="32"
                                Click="ButtonUpdates_Click">
                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                <ctrl:Icon IconName="package" Width="14" Height="14" VerticalAlignment="Center" />
                                <TextBlock Text="Updates" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="3" x:Name="buttonQuit" Classes="ghelper"
                                Height="32"
                                Click="ButtonQuit_Click">
                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                <ctrl:Icon IconName="power" Width="14" Height="14" VerticalAlignment="Center" />
                                <TextBlock Text="Quit" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Hidden labels kept for code-behind compatibility -->
            <TextBlock x:Name="labelPerfMode" IsVisible="False" Text="" />
            <TextBlock x:Name="labelGPUMode" IsVisible="False" Text="" />
            <TextBlock x:Name="labelScreenHz" IsVisible="False" Text="" />
            <TextBlock x:Name="labelBatteryTitle" IsVisible="False" Text="" />

        </StackPanel>
    </ScrollViewer>

</Window>
