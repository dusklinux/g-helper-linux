<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GHelper.Linux.UI.Views.ExtraWindow"
        Title="Extra Settings"
        Width="520"
        Height="700"
        MinWidth="420"
        MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#1C1C1C"
        Icon="avares://ghelper/UI/Assets/standard.ico">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10" Spacing="5">

            <!-- LANGUAGE -->
            <Border Classes="panel">
                <StackPanel>
                    <Border Classes="panel-header" Margin="0,0,0,8">
                        <TextBlock x:Name="labelLanguageHeader" Classes="header" Text="Language" />
                    </Border>
                    <Grid ColumnDefinitions="120,*" Margin="0,4">
                        <TextBlock Grid.Column="0" x:Name="labelLanguageLabel" Text="Language"
                                   Classes="label-dim" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" x:Name="comboLanguage"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="ComboLanguage_Changed" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- KEYBOARD BACKLIGHT -->
            <Border Classes="panel">
                <StackPanel>
                    <Border Classes="panel-header" Margin="0,0,0,8">
                        <TextBlock x:Name="headerKbdBacklight" Classes="header" Text="Keyboard Backlight" />
                    </Border>

                    <!-- Brightness slider (0-3) -->
                    <Grid ColumnDefinitions="120,*,40" Margin="0,4">
                        <TextBlock Grid.Column="0" x:Name="labelKbdBrightnessLabel" Text="Brightness"
                                   Classes="label-dim" VerticalAlignment="Center" />
                        <Slider Grid.Column="1" x:Name="sliderKbdBrightness"
                                Minimum="0" Maximum="3" Value="3"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="SliderKbdBrightness_ValueChanged" />
                        <TextBlock Grid.Column="2" x:Name="labelKbdBrightness"
                                   Classes="value" Text="3"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>

                    <!-- Animation Speed -->
                    <Grid ColumnDefinitions="120,*" Margin="0,4">
                        <TextBlock Grid.Column="0" x:Name="labelAnimSpeed" Text="Animation Speed"
                                   Classes="label-dim" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" x:Name="comboKbdSpeed"
                                  Width="120" Height="28"
                                  SelectionChanged="ComboKbdSpeed_Changed" />
                    </Grid>

                    <!-- Power Zone Checkboxes -->
                    <TextBlock x:Name="labelPowerZones" Text="Power Zones" Classes="label-dim" Margin="0,8,0,4" FontWeight="SemiBold" />

                    <!-- Header row -->
                    <Grid ColumnDefinitions="80,60,60,60,60,60" Margin="0,2">
                        <TextBlock Grid.Column="0" Text="" />
                        <TextBlock Grid.Column="1" x:Name="labelColAwake" Text="Awake" Classes="label-dim" FontSize="10" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="2" x:Name="labelColBoot" Text="Boot" Classes="label-dim" FontSize="10" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="3" x:Name="labelColSleep" Text="Sleep" Classes="label-dim" FontSize="10" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="4" x:Name="labelColShutdown" Text="Shutdown" Classes="label-dim" FontSize="10" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="5" x:Name="labelColBattery" Text="Battery" Classes="label-dim" FontSize="10" HorizontalAlignment="Center" />
                    </Grid>

                    <!-- Keyboard row -->
                    <Grid ColumnDefinitions="80,60,60,60,60,60" Margin="0,1" x:Name="rowPowerKeyboard">
                        <TextBlock Grid.Column="0" x:Name="labelRowKeyboard" Text="Keyboard" Classes="label-dim" FontSize="11" VerticalAlignment="Center" />
                        <CheckBox Grid.Column="1" x:Name="checkAwake" HorizontalAlignment="Center" IsCheckedChanged="CheckPower_Changed" />
                        <CheckBox Grid.Column="2" x:Name="checkBoot" HorizontalAlignment="Center" IsCheckedChanged="CheckPower_Changed" />
                        <CheckBox Grid.Column="3" x:Name="checkSleep" HorizontalAlignment="Center" IsCheckedChanged="CheckPower_Changed" />
                        <CheckBox Grid.Column="4" x:Name="checkShutdown" HorizontalAlignment="Center" IsCheckedChanged="CheckPower_Changed" />
                        <CheckBox Grid.Column="5" x:Name="checkBattery" HorizontalAlignment="Center" IsCheckedChanged="CheckPower_Changed" />
                    </Grid>

                    <!-- Logo row -->
                    <Grid ColumnDefinitions="80,60,60,60,60,60" Margin="0,1" x:Name="rowPowerLogo">
                        <TextBlock Grid.Column="0" x:Name="labelRowLogo" Text="Logo" Classes="label-dim" FontSize="11" VerticalAlignment="Center" />
                        <CheckBox Grid.Column="1" x:Name="checkAwakeLogo" HorizontalAlignment="Center" IsCheckedChanged="CheckPower_Changed" />
                        <CheckBox Grid.Column="2" x:Name="checkBootLogo" HorizontalAlignment="Center" IsCheckedChanged="CheckPower_Changed" />
                        <CheckBox Grid.Column="3" x:Name="checkSleepLogo" HorizontalAlignment="Center" IsCheckedChanged="CheckPower_Changed" />
                        <CheckBox Grid.Column="4" x:Name="checkShutdownLogo" HorizontalAlignment="Center" IsCheckedChanged="CheckPower_Changed" />
                        <CheckBox Grid.Column="5" x:Name="checkBatteryLogo" HorizontalAlignment="Center" IsCheckedChanged="CheckPower_Changed" />
                    </Grid>

                    <!-- Lightbar row -->
                    <Grid ColumnDefinitions="80,60,60,60,60,60" Margin="0,1" x:Name="rowPowerBar">
                        <TextBlock Grid.Column="0" x:Name="labelRowLightbar" Text="Lightbar" Classes="label-dim" FontSize="11" VerticalAlignment="Center" />
                        <CheckBox Grid.Column="1" x:Name="checkAwakeBar" HorizontalAlignment="Center" IsCheckedChanged="CheckPower_Changed" />
                        <CheckBox Grid.Column="2" x:Name="checkBootBar" HorizontalAlignment="Center" IsCheckedChanged="CheckPower_Changed" />
                        <CheckBox Grid.Column="3" x:Name="checkSleepBar" HorizontalAlignment="Center" IsCheckedChanged="CheckPower_Changed" />
                        <CheckBox Grid.Column="4" x:Name="checkShutdownBar" HorizontalAlignment="Center" IsCheckedChanged="CheckPower_Changed" />
                        <CheckBox Grid.Column="5" x:Name="checkBatteryBar" HorizontalAlignment="Center" IsCheckedChanged="CheckPower_Changed" />
                    </Grid>

                    <!-- Lid row -->
                    <Grid ColumnDefinitions="80,60,60,60,60,60" Margin="0,1" x:Name="rowPowerLid">
                        <TextBlock Grid.Column="0" x:Name="labelRowLid" Text="Lid" Classes="label-dim" FontSize="11" VerticalAlignment="Center" />
                        <CheckBox Grid.Column="1" x:Name="checkAwakeLid" HorizontalAlignment="Center" IsCheckedChanged="CheckPower_Changed" />
                        <CheckBox Grid.Column="2" x:Name="checkBootLid" HorizontalAlignment="Center" IsCheckedChanged="CheckPower_Changed" />
                        <CheckBox Grid.Column="3" x:Name="checkSleepLid" HorizontalAlignment="Center" IsCheckedChanged="CheckPower_Changed" />
                        <CheckBox Grid.Column="4" x:Name="checkShutdownLid" HorizontalAlignment="Center" IsCheckedChanged="CheckPower_Changed" />
                        <CheckBox Grid.Column="5" x:Name="checkBatteryLid" HorizontalAlignment="Center" IsCheckedChanged="CheckPower_Changed" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- DISPLAY SETTINGS -->
            <Border Classes="panel">
                <StackPanel>
                    <Border Classes="panel-header" Margin="0,0,0,8">
                        <TextBlock x:Name="headerDisplay" Classes="header" Text="Display" />
                    </Border>

                    <!-- Backlight controller selector (visible when multiple backlight devices) -->
                    <Grid x:Name="rowBacklightSelector" ColumnDefinitions="120,*" Margin="0,4" IsVisible="False">
                        <TextBlock Grid.Column="0" x:Name="labelControllerLabel" Text="Controller"
                                   Classes="label-dim" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" x:Name="comboBacklight"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="ComboBacklight_SelectionChanged" />
                    </Grid>

                    <!-- Brightness slider (visible when backlight device exists) -->
                    <Grid x:Name="rowBrightnessSlider" ColumnDefinitions="120,*,50" Margin="0,4">
                        <TextBlock Grid.Column="0" x:Name="labelDisplayBrightnessLabel" Text="Brightness"
                                   Classes="label-dim" VerticalAlignment="Center" />
                        <Slider Grid.Column="1" x:Name="sliderBrightness"
                                Minimum="4" Maximum="100" Value="100"
                                ValueChanged="SliderBrightness_ValueChanged" />
                        <TextBlock Grid.Column="2" x:Name="labelBrightness"
                                   Classes="value" Text="100%"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>

                    <!-- Backlight enable button (visible when no backlight + loadable module) -->
                    <Button x:Name="buttonEnableBacklight"
                            Content="Enable display backlight"
                            IsVisible="False" Margin="0,4"
                            Click="ButtonEnableBacklight_Click" />

                    <!-- Backlight hint (visible when no backlight + no loadable module) -->
                    <TextBlock x:Name="labelBacklightHint"
                               IsVisible="False" Classes="label-dim"
                               Margin="0,4" TextWrapping="Wrap" FontSize="11" />

                    <!-- Panel Overdrive -->
                    <CheckBox x:Name="checkOverdrive" Content="Panel Overdrive"
                              Margin="0,4"
                              IsCheckedChanged="CheckOverdrive_Changed" />

                    <!-- Gamma (hidden on Wayland, no backend support) -->
                    <Grid x:Name="rowGamma" ColumnDefinitions="120,*,50" Margin="0,4">
                        <TextBlock Grid.Column="0" x:Name="labelGammaLabel" Text="Gamma"
                                   Classes="label-dim" VerticalAlignment="Center" />
                        <Slider Grid.Column="1" x:Name="sliderGamma"
                                Minimum="50" Maximum="200" Value="100"
                                TickFrequency="10"
                                ValueChanged="SliderGamma_ValueChanged" />
                        <TextBlock Grid.Column="2" x:Name="labelGamma"
                                   Classes="value" Text="1.00"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>


            <Border Classes="panel" x:Name="panelGpuTuning" IsVisible="False">
                <StackPanel>
                    <Border Classes="panel-header" Margin="0,0,0,8">
                        <TextBlock x:Name="headerGpuTuning" Classes="header" Text="GPU Tuning" />
                    </Border>

                    <TextBlock x:Name="labelGpuTuningInfo" Classes="label-dim"
                               Text="NVIDIA GPU" Margin="0,0,0,6" />

                    <!-- Power Limit slider -->
                    <Grid ColumnDefinitions="110,*,50" Margin="0,4">
                        <TextBlock Grid.Column="0" x:Name="labelPowerLimitLabel" Text="Power Limit"
                                   Classes="label-dim" VerticalAlignment="Center" />
                        <Slider Grid.Column="1" x:Name="sliderGpuPowerLimit"
                                Minimum="5" Maximum="115" Value="55"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                ValueChanged="SliderGpuPowerLimit_ValueChanged" />
                        <TextBlock Grid.Column="2" x:Name="labelGpuPowerLimit"
                                   Classes="value" Text="55W"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>

                    <!-- Clock Lock -->
                    <Grid ColumnDefinitions="110,Auto,*,50" Margin="0,4">
                        <TextBlock Grid.Column="0" x:Name="labelClockLockLabel" Text="Clock Lock"
                                   Classes="label-dim" VerticalAlignment="Center" />
                        <CheckBox Grid.Column="1" x:Name="checkGpuClockLock"
                                  Margin="0,0,8,0" VerticalAlignment="Center"
                                  IsCheckedChanged="CheckGpuClockLock_Changed" />
                        <Slider Grid.Column="2" x:Name="sliderGpuClockLock"
                                Minimum="200" Maximum="3000" Value="2400"
                                TickFrequency="50" IsSnapToTickEnabled="True"
                                IsEnabled="False"
                                ValueChanged="SliderGpuClockLock_ValueChanged" />
                        <TextBlock Grid.Column="3" x:Name="labelGpuClockLock"
                                   Classes="value" Text="--"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>

                    <Button x:Name="buttonGpuApply" Classes="ghelper"
                            Content="Apply GPU Settings" Margin="0,8,0,0"
                            Click="ButtonGpuApply_Click" />
                </StackPanel>
            </Border>

            <!-- OTHER SETTINGS -->
            <Border Classes="panel">
                <StackPanel>
                    <Border Classes="panel-header" Margin="0,0,0,8">
                        <TextBlock x:Name="headerOther" Classes="header" Text="Other" />
                    </Border>

                    <CheckBox x:Name="checkBootSound" Content="Boot Sound"
                              Margin="0,4"
                              IsCheckedChanged="CheckBootSound_Changed" />

                    <CheckBox x:Name="checkPerKeyRGB" Content="Per-Key RGB (instead of 4-zone)"
                              Margin="0,4" IsVisible="False"
                              IsCheckedChanged="CheckPerKeyRGB_Changed" />

                    <CheckBox x:Name="checkTopmost" Content="Window Always on Top"
                              Margin="0,4"
                              IsCheckedChanged="CheckTopmost_Changed" />

                    <CheckBox x:Name="checkBWIcon" Content="B&amp;W Tray Icon"
                              Margin="0,4"
                              IsCheckedChanged="CheckBWIcon_Changed" />

                    <CheckBox x:Name="checkClamshell" Content="Clamshell Mode (disable sleep on lid close)"
                              Margin="0,4"
                              IsCheckedChanged="CheckClamshell_Changed" />

                    <CheckBox x:Name="checkSilentStart" Content="Start minimized to tray"
                              Margin="0,4"
                              IsCheckedChanged="CheckSilentStart_Changed" />

                    <Separator Margin="0,8,0,4" />

                    <!-- Device toggles -->
                    <CheckBox x:Name="checkCamera" Content="Camera"
                              Margin="0,4"
                              IsCheckedChanged="CheckCamera_Changed" />

                    <CheckBox x:Name="checkTouchpad" Content="Touchpad"
                              Margin="0,4"
                              IsCheckedChanged="CheckTouchpad_Changed" />

                    <CheckBox x:Name="checkTouchscreen" Content="Touchscreen"
                              Margin="0,4" IsVisible="False"
                              IsCheckedChanged="CheckTouchscreen_Changed" />
                </StackPanel>
            </Border>

            <!-- KEY BINDINGS -->
            <Border Classes="panel">
                <StackPanel>
                    <Border Classes="panel-header" Margin="0,0,0,8">
                        <TextBlock x:Name="headerKeyBindings" Classes="header" Text="Key Bindings" />
                    </Border>

                    <!-- ROG / M5 Key -->
                    <Grid ColumnDefinitions="180,*" Margin="0,4">
                        <TextBlock Grid.Column="0" x:Name="labelKeyM4" Text="ROG / M5 Key"
                                   Classes="label-dim" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" x:Name="comboKeyM4"
                                  Width="220" Height="28"
                                  SelectionChanged="ComboKeyBinding_Changed" />
                    </Grid>

                    <!-- Fn+F4 (Aura) -->
                    <Grid ColumnDefinitions="180,*" Margin="0,4">
                        <TextBlock Grid.Column="0" x:Name="labelKeyFnF4" Text="Fn+F4 (Aura)"
                                   Classes="label-dim" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" x:Name="comboKeyFnF4"
                                  Width="220" Height="28"
                                  SelectionChanged="ComboKeyBinding_Changed" />
                    </Grid>

                    <!-- Fn+F5 / M4 (Performance) -->
                    <Grid ColumnDefinitions="180,*" Margin="0,4">
                        <TextBlock Grid.Column="0" x:Name="labelKeyFnF5" Text="Fn+F5 / M4"
                                   Classes="label-dim" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" x:Name="comboKeyFnF5"
                                  Width="220" Height="28"
                                  SelectionChanged="ComboKeyBinding_Changed" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- POWER MANAGEMENT -->
            <Border Classes="panel">
                <StackPanel>
                    <Border Classes="panel-header" Margin="0,0,0,8">
                        <TextBlock x:Name="headerPowerMgmt" Classes="header" Text="Power Management" />
                    </Border>

                    <!-- Platform Profile -->
                    <Grid ColumnDefinitions="120,*" Margin="0,4">
                        <TextBlock Grid.Column="0" x:Name="labelPlatformProfileLabel" Text="Platform Profile"
                                   Classes="label-dim" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" x:Name="comboPlatformProfile"
                                  Width="200" SelectionChanged="ComboPlatformProfile_Changed">
                            <ComboBoxItem Content="low-power" />
                            <ComboBoxItem Content="balanced" />
                            <ComboBoxItem Content="performance" />
                        </ComboBox>
                    </Grid>

                    <!-- ASPM Policy -->
                    <Grid ColumnDefinitions="120,*" Margin="0,4">
                        <TextBlock Grid.Column="0" x:Name="labelAspmLabel" Text="PCIe ASPM"
                                   Classes="label-dim" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" x:Name="comboAspm"
                                  Width="200" SelectionChanged="ComboAspm_Changed">
                            <ComboBoxItem Content="default" />
                            <ComboBoxItem Content="performance" />
                            <ComboBoxItem Content="powersave" />
                            <ComboBoxItem Content="powersupersave" />
                        </ComboBox>
                    </Grid>

                    <!-- Battery Health -->
                    <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="labelBatteryHealth" Classes="label-dim"
                                       Text="Battery health: --%" />
                            <TextBlock x:Name="labelPowerDraw" Classes="label-dim"
                                       Text="Power draw: - mW" Margin="0,4,0,0" />
                        </StackPanel>
                        <Button Grid.Column="1" x:Name="buttonBatteryInfo" Classes="ghelper"
                                Height="28" VerticalAlignment="Center"
                                Click="ButtonBatteryInfo_Click">
                            <TextBlock x:Name="labelBatteryDetails" Text="Details..." FontSize="11" />
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- SYSTEM INFO -->
            <Border Classes="panel">
                <StackPanel>
                    <Border Classes="panel-header" Margin="0,0,0,8">
                        <TextBlock x:Name="headerSystemInfo" Classes="header" Text="System Info" />
                    </Border>

                    <TextBlock x:Name="labelModel" Classes="label-dim"
                               Text="Model: --" />
                    <TextBlock x:Name="labelBios" Classes="label-dim"
                               Text="BIOS: --" Margin="0,4,0,0" />
                    <TextBlock x:Name="labelKernel" Classes="label-dim"
                               Text="Kernel: --" Margin="0,4,0,0" />
                    <TextBlock x:Name="labelAsusWmi" Classes="label-dim"
                               Text="asus-wmi: --" Margin="0,4,0,0" />
                    <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                        <TextBlock Grid.Column="0" x:Name="labelFeatures" Classes="label-dim"
                                   Text="" TextWrapping="Wrap" VerticalAlignment="Center" />
                        <Button Grid.Column="1" x:Name="buttonSystemInfo" Classes="ghelper"
                                Height="28" VerticalAlignment="Center"
                                Click="ButtonSystemInfo_Click">
                            <TextBlock x:Name="labelSystemInfoMore" Text="More..." FontSize="11" />
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ADVANCED -->
            <Border Classes="panel">
                <StackPanel>
                    <Border Classes="panel-header" Margin="0,0,0,8">
                        <TextBlock x:Name="headerAdvanced" Classes="header" Text="Advanced" />
                    </Border>

                    <CheckBox x:Name="checkAutoApplyPower" Content="Auto-apply power limits on mode change"
                              Margin="0,4"
                              IsCheckedChanged="CheckAutoApplyPower_Changed" />

                    <CheckBox x:Name="checkRawWmi"
                              Content="Raw WMI mode (experimental - GPU Eco via ACPI debugfs)"
                              Margin="0,4"
                              IsCheckedChanged="CheckRawWmi_Changed" />
                    <TextBlock x:Name="labelRawWmiHint" Classes="label-dim"
                               Text="For laptops without GPU Eco sysfs. App will restart when toggled."
                               FontSize="10" Margin="20,0,0,4" />

                    <CheckBox x:Name="checkScreenAuto" Content="Auto-switch refresh rate (AC/Battery)"
                              Margin="0,4"
                              IsCheckedChanged="CheckScreenAuto_Changed" />

                    <!-- CPU Cores -->
                    <Grid ColumnDefinitions="120,*,50" Margin="0,8,0,4" x:Name="panelCpuCores">
                        <TextBlock Grid.Column="0" x:Name="labelCpuCoresLabel" Text="CPU Cores"
                                   Classes="label-dim" VerticalAlignment="Center" />
                        <Slider Grid.Column="1" x:Name="sliderCpuCores"
                                Minimum="1" Maximum="32" Value="32"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="SliderCpuCores_ValueChanged" />
                        <TextBlock Grid.Column="2" x:Name="labelCpuCores" Classes="value"
                                   Text="32" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock x:Name="labelCpuCoresInfo" Classes="label-dim"
                               Text="" FontSize="10" Margin="0,0,0,4" />

                    <Button x:Name="buttonOpenLog" Classes="ghelper"
                            Content="Open Log File" Margin="0,8,0,0"
                            Click="ButtonOpenLog_Click" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</Window>
