<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GHelper.Linux.UI.Views.SystemInfoWindow"
        Title="System Information"
        Width="560"
        Height="700"
        MinWidth="440"
        MinHeight="400"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        Background="#1C1C1C"
        Icon="avares://ghelper/UI/Assets/standard.ico">

    <DockPanel>
        <!-- Copy button pinned at top -->
        <Border DockPanel.Dock="Top" Margin="12,12,12,0">
            <Button x:Name="buttonCopy" Classes="ghelper"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Click="ButtonCopy_Click">
                <TextBlock x:Name="labelCopyButton" Text="Copy to Clipboard" />
            </Button>
        </Border>

        <!-- Scrollable content area (panels built dynamically) -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,6,0,0">
            <StackPanel x:Name="contentPanel" Margin="12,0,12,12" Spacing="6" />
        </ScrollViewer>
    </DockPanel>

</Window>
