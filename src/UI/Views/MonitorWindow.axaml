<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
        x:Class="GHelper.Linux.UI.Views.MonitorWindow"
        Title="Hardware Monitor"
        Width="820"
        Height="820"
        MinWidth="620"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#1C1C1C"
        Icon="avares://ghelper/UI/Assets/standard.ico">

    <Grid RowDefinitions="Auto,*,*,*" Margin="10">

        <!-- HEADER -->
        <StackPanel Grid.Row="0" Margin="4,0,0,6">
            <TextBlock x:Name="headerMonitor" Classes="header" Text="Hardware Monitor"
                       FontSize="14" Margin="0,0,0,2" TextWrapping="Wrap" />
            <TextBlock x:Name="labelLiveStats" Classes="label-dim"
                       Text="" Margin="0,0,0,2" TextWrapping="Wrap" />
        </StackPanel>

        <!-- TEMPERATURE CHART -->
        <Border Grid.Row="1" Classes="panel" Margin="0,0,0,4" Padding="6,6,6,2">
            <lvc:CartesianChart x:Name="chartTemperature" />
        </Border>

        <!-- FAN SPEED CHART -->
        <Border Grid.Row="2" Classes="panel" Margin="0,0,0,4" Padding="6,6,6,2">
            <lvc:CartesianChart x:Name="chartFanSpeed" />
        </Border>

        <!-- POWER & LOAD CHART -->
        <Border Grid.Row="3" Classes="panel" Margin="0,0,0,0" Padding="6,6,6,2">
            <lvc:CartesianChart x:Name="chartPower" />
        </Border>

    </Grid>

</Window>
